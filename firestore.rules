rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // HELPER FUNCTIONS (RBAC & Boundaries)
    // ==========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isSuperAdmin() {
      return hasRole('SUPER_ADMIN');
    }
    
    function isAdmin() {
      return hasRole('SUPER_ADMIN') || hasRole('ADMIN');
    }
    
    function isTempleAdminFor(templeId) {
      return hasRole('TEMPLE_ADMIN') && request.auth.token.templeId == templeId;
    }
    
    function isProFor(templeId) {
      return hasRole('PRO') && request.auth.token.templeId == templeId;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Soft Delete check
    function isNotDeleted(resourceData) {
      return !('isDeleted' in resourceData) || resourceData.isDeleted == false;
    }

    // ==========================================
    // COLLECTIONS
    // ==========================================

    match /appConfigs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && (!request.resource.data.keys().hasAll(['isDeleted']) || isAdmin());
      allow delete: if false; // Use soft delete
    }

    match /userSessions/{sessionId} {
      // User can read their own sessions. Admin can read all.
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      // User can create their own session
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // User can update their own session (e.g. lastSeen), Admin can deactivate
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if false;
    }

    match /temples/{templeId} {
      allow read: if (isNotDeleted(resource.data) && resource.data.isActive == true) || 
                     isTempleAdminFor(templeId) || 
                     isAdmin();
      allow write: if isAdmin();
      allow update: if isTempleAdminFor(templeId) || isAdmin();
      allow delete: if false;
    }

    match /poojas/{poojaId} {
      allow read: if (isNotDeleted(resource.data) && resource.data.isActive == true) || 
                     isTempleAdminFor(resource.data.templeId) || 
                     isAdmin();
      allow write: if isAdmin() || isTempleAdminFor(request.resource.data.templeId);
      allow delete: if false;
    }

    match /priests/{priestId} {
      allow read: if isNotDeleted(resource.data) || isTempleAdminFor(resource.data.templeId) || isAdmin();
      allow create: if isAdmin() || isTempleAdminFor(request.resource.data.templeId);
      allow update: if isAdmin() || isTempleAdminFor(resource.data.templeId) || 
                       (hasRole('PRO') && request.auth.uid == resource.data.userId);
      allow delete: if false;
    }

    match /slots/{slotId} {
      allow read: if isNotDeleted(resource.data) || isAdmin() || isProFor(resource.data.templeId);
      allow create: if isAdmin() || isProFor(request.resource.data.templeId);
      allow update: if isAdmin() || isProFor(resource.data.templeId) || 
                       // Users can update via booking transactions (managed by CF preferably, but if direct:)
                       isAuthenticated(); // In practice, seat decrements should happen in Cloud Functions or secure transactions
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isOwner(resource.data.userId) || 
                     isProFor(resource.data.templeId) || 
                     isTempleAdminFor(resource.data.templeId) ||
                     isAdmin();
      
      allow create: if isOwner(request.resource.data.userId);
      
      allow update: if isAdmin() || 
                       isProFor(resource.data.templeId) || 
                       (isOwner(resource.data.userId) && request.resource.data.status == 'CANCELLED'); // User can only cancel
                       
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false; // System only (Cloud Functions)
    }

    match /refunds/{refundId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /deliveries/{deliveryId} {
      allow read: if isOwner(resource.data.userId) || isProFor(get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.templeId) || isAdmin();
      allow update: if isProFor(get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.templeId) || isAdmin();
      allow create, delete: if false; // CF generated
    }

    match /liveStreams/{streamId} {
      allow read: if true; // Public or booked users, specific filtering in app
      allow write: if isAdmin() || isProFor(request.resource.data.templeId);
      allow delete: if false;
    }

    match /recordings/{recordingId} {
      allow read: if resource.data.isPublished == true || isAdmin() || isProFor(get(/databases/$(database)/documents/liveStreams/$(resource.data.streamId)).data.templeId);
      allow create: if isAdmin() || isProFor(get(/databases/$(database)/documents/liveStreams/$(request.resource.data.streamId)).data.templeId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if resource.data.isPublished == true || isAdmin() || isProFor(get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.templeId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create, delete: if false; // System generated
    }

    match /festivals/{festivalId} {
      allow read: if isNotDeleted(resource.data) && resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Strictly CF generated
    }

    match /systemEvents/{eventId} {
      allow read, write: if false; // Strictly Server/Admin SDK only
    }

  }
}
